{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "preDeployCommand": "python manage.py migrate --run-syncdb --noinput",
    "healthcheckPath": "/health/",
    "startCommand": "python manage.py collectstatic --noinput && gunicorn project.wsgi:application --bind 0.0.0.0:$PORT"
  }
}
